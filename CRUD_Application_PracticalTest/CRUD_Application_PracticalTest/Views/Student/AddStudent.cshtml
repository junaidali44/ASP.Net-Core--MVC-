@model CRUDApplication.ViewModel.StudentViewModel

<h1>Add Student</h1>

<div class="container">
    <form class="form" asp-action="AddStudent" asp-controller="Student" method="post">
        <div class="mb-3">
            <label asp-for="StudentName" class="form-label">Enter Student Name</label>
            <input asp-for="StudentName" class="form-control" type="text" />
        </div>
        <div class="mb-3">
            <label asp-for="StudentEmail" class="form-label">Enter Student Email</label>
            <input asp-for="StudentEmail" class="form-control" type="email" />
        </div>
        <div class="mb-3">
            <label asp-for="DateOfBirth" class="form-label">Enter Student Date of Birth</label>
            <input asp-for="DateOfBirth" class="form-control" type="date" />
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Save Student</button>
        </div>
    </form>
</div>
