@model ABCDMallWebsite.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AccountLayout";
}

<div class="auth-card">
    <div class="auth-header">
        <div class="auth-icon">
            <i class="fas fa-key"></i>
        </div>
        <h2>Forgot Password</h2>
        <p>Enter your email to reset your password</p>
    </div>
    
    <div class="auth-body">
        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-danger"></div>
            
            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="Enter your registered email" />
                </div>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            
            <button type="submit" class="btn btn-auth">
                <i class="fas fa-paper-plane"></i> Send Reset Link
            </button>
        </form>
        
        <div class="auth-footer">
            <p><a asp-action="Login">Back to Login</a></p>
        </div>
    </div>
</div>