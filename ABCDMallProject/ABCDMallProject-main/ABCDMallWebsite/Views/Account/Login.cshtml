@model ABCDMallWebsite.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_AccountLayout";
}

<div class="auth-card">
    <div class="auth-header">
        <div class="auth-icon">
            <i class="fas fa-store"></i>
        </div>
        <h2>Welcome Back</h2>
        <p>Please login to your account</p>
    </div>
    
    <div class="auth-body">
        @if (TempData["Success"] != null)
        {
            <div class="auth-alert auth-alert-success">
                <i class="fas fa-check-circle"></i>
                <span>@TempData["Success"]</span>
            </div>
        }
        
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-danger"></div>
            
            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                </div>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                </div>
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>
            
            <div class="form-options">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                </div>
                <a asp-action="ForgotPassword" class="forgot-link">Forgot Password?</a>
            </div>
            
            <button type="submit" class="btn btn-auth">
                <i class="fas fa-sign-in-alt"></i> Login
            </button>
        </form>
        
        <div class="auth-divider">
            <span>OR</span>
        </div>
        
        <div class="auth-footer">
            <p>Don't have an account? <a asp-action="Register">Create Account</a></p>
        </div>
    </div>
</div>