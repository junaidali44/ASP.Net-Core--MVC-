@model ABCDMallWebsite.ViewModels.ProfileViewModel;
@{
    ViewData["Title"] = "My Profile";
    Layout = "_AccountLayout";
}

<div class="auth-card">
    <div class="profile-header">
        <div class="profile-avatar">
            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
            {
                <img src="@Model.ProfilePictureUrl" alt="Profile Picture" id="profileImage" />
            }
            else
            {
                <i class="fas fa-user-circle" id="profileIcon"></i>
            }
        </div>
        <div class="profile-name">@Model.FullName</div>
        <div class="profile-email">@Model.Email</div>
        <div class="profile-stats">
            <div class="stat">
                <div class="stat-number">@ViewBag.UserBookings?.Count</div>
                <div class="stat-label">Bookings</div>
            </div>
            <div class="stat">
                <div class="stat-number">0</div>
                <div class="stat-label">Reviews</div>
            </div>
        </div>
    </div>
    
    <div class="auth-body">
        <div class="profile-tabs">
            <button class="profile-tab active" data-tab="info">
                <i class="fas fa-user"></i> Personal Info
            </button>
            <button class="profile-tab" data-tab="bookings">
                <i class="fas fa-ticket-alt"></i> My Bookings
            </button>
        </div>
        
        <!-- Personal Info Tab -->
        <div id="tab-info" class="tab-content active">
            <form asp-controller="Account" asp-action="Profile" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="auth-alert auth-alert-danger"></div>
                
                <div class="form-group">
                    <label asp-for="FullName">Full Name</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                        <input asp-for="FullName" class="form-control" />
                    </div>
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>
                
                <div class="form-group">
                    <label asp-for="Email">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" readonly disabled />
                    </div>
                </div>
                
                <div class="form-group">
                    <label asp-for="PhoneNumber">Phone Number</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-phone"></i></span>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                </div>
                
                <div class="form-group">
                    <label asp-for="Address">Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <span asp-validation-for="Address" class="field-validation-error"></span>
                </div>
                
                <div class="form-group">
                    <label asp-for="DateOfBirth">Date of Birth</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                    </div>
                    <span asp-validation-for="DateOfBirth" class="field-validation-error"></span>
                </div>
                
                <div class="form-group">
                    <label>Profile Picture</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-image"></i></span>
                        <input type="file" name="profilePicture" class="form-control" accept="image/*" id="profilePictureInput" />
                    </div>
                    <small class="text-muted">Max 5MB. Allowed: JPG, PNG</small>
                </div>
                
                <div class="form-options" style="justify-content: space-between; margin-top: 20px;">
                    <button type="submit" class="btn btn-auth" style="width: auto; padding: 10px 25px;">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                    <a asp-action="ChangePassword" class="btn-outline-primary">
                        <i class="fas fa-key"></i> Change Password
                    </a>
                </div>
            </form>
        </div>
        
        <!-- Bookings Tab -->
        <div id="tab-bookings" class="tab-content">
            @if (ViewBag.UserBookings != null && ((ICollection<ABCDMallWebsite.Models.Booking>)ViewBag.UserBookings).Count > 0)
            {
                var bookings = ViewBag.UserBookings as IEnumerable<ABCDMallWebsite.Models.Booking>;
                foreach (var booking in bookings)
                {
                    <div class="booking-card">
                        @if (booking.Movie != null && !string.IsNullOrEmpty(booking.Movie.PosterUrl))
                        {
                            <img src="@booking.Movie.PosterUrl" class="booking-poster" alt="@booking.Movie.Name" />
                        }
                        else
                        {
                            <div class="booking-poster bg-secondary d-flex align-items-center justify-content-center">
                                <i class="fas fa-film text-white"></i>
                            </div>
                        }
                        <div class="booking-info">
                            <div class="booking-movie">@booking.Movie?.Name ?? "Movie Not Found"</div>
                            <div class="booking-details">
                                <i class="fas fa-calendar"></i> @booking.BookingDate.ToString("dd MMM yyyy") |
                                <i class="fas fa-ticket-alt"></i> @booking.NumberOfSeats seats |
                                <i class="fas fa-rupee-sign"></i> @booking.TotalAmount
                            </div>
                            <div class="booking-details">
                                Booking ID: @booking.BookingReference
                            </div>
                        </div>
                        <div>
                            <span class="booking-status status-confirmed">@booking.BookingStatus</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-ticket-alt" style="font-size: 60px; color: var(--gray); margin-bottom: 15px;"></i>
                    <p>No bookings found.</p>
                    <a href="/Movies" class="btn btn-auth" style="width: auto; padding: 10px 25px;">
                        <i class="fas fa-film"></i> Book Movies Now
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tab switching
        document.querySelectorAll('.profile-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                const tabId = this.dataset.tab;
                
                // Remove active class from all tabs and contents
                document.querySelectorAll('.profile-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
                
                // Add active class to clicked tab
                this.classList.add('active');
                document.getElementById(`tab-${tabId}`).classList.add('active');
            });
        });
        
        // Profile picture preview
        const profilePictureInput = document.getElementById('profilePictureInput');
        if (profilePictureInput) {
            profilePictureInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const avatar = document.querySelector('.profile-avatar');
                        const existingImg = document.querySelector('.profile-avatar img');
                        const existingIcon = document.querySelector('.profile-avatar i');
                        
                        if (existingImg) {
                            existingImg.src = event.target.result;
                        } else if (existingIcon) {
                            // Replace icon with image
                            const newImg = document.createElement('img');
                            newImg.id = 'profileImage';
                            newImg.src = event.target.result;
                            avatar.innerHTML = '';
                            avatar.appendChild(newImg);
                        } else {
                            const newImg = document.createElement('img');
                            newImg.id = 'profileImage';
                            newImg.src = event.target.result;
                            avatar.appendChild(newImg);
                        }
                    };
                    reader.readAsDataURL(file);
                }
            });
        }
    </script>
}