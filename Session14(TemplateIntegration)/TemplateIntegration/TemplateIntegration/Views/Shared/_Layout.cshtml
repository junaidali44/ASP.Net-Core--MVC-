						</div>
					</div>
					<div class="col-sm-8">
						<div class="mainmenu text-center">
							<nav>
								<ul>
									<li><a asp-controller="Home" asp-action="Index" >Home</a></li>
									<li><a asp-controller="Home" asp-action="Services" >Services</a></li>
									<li><a asp-controller="Home" asp-action="Gallery" >Gallery</a></li>
