<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>About Us</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
        }

        .hero {
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
                        url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f');
            background-size: cover;
            background-position: center;
            color: white;
            padding: 120px 0;
            text-align: center;
        }

        .section-padding {
            padding: 80px 0;
        }

        .icon-box {
            background: #f8f9fa;
            padding: 30px;
            border-radius: 10px;
            transition: 0.3s;
        }

        .icon-box:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .team-card img {
            border-radius: 50%;
            width: 150px;
            height: 150px;
            object-fit: cover;
        }

        .cta {
            background: #0d6efd;
            color: white;
            padding: 60px 0;
            text-align: center;
        }

        .btn-custom {
            background: white;
            color: #0d6efd;
            font-weight: 600;
        }

        .btn-custom:hover {
            background: #f1f1f1;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">YourBrand</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link active" href="#">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1 class="display-4 fw-bold">About Our Company</h1>
            <p class="lead mt-3">We build innovative solutions that drive growth and success.</p>
            <a href="#" class="btn btn-primary btn-lg mt-3">Get in Touch</a>
        </div>
    </section>

    <!-- About Section -->
    <section class="section-padding">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <img src="https://images.unsplash.com/photo-1552664730-d307ca884978" class="img-fluid rounded shadow" alt="About">
                </div>
                <div class="col-md-6">
                    <h2 class="fw-bold">Our Story</h2>
                    <p class="mt-3 text-muted">
                        Founded with passion and purpose, we aim to deliver high-quality services
                        that help businesses grow. Our journey started with a simple mission:
                        create value through innovation and trust.
                    </p>
                    <p class="text-muted">
                        Today, we proudly serve clients across multiple industries, building long-term partnerships.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="bg-light section-padding">
        <div class="container text-center">
            <h2 class="fw-bold mb-5">Our Mission & Vision</h2>
            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="icon-box">
                        <h4 class="fw-bold">Our Mission</h4>
                        <p class="text-muted mt-3">
                            To empower businesses with scalable, innovative, and impactful solutions.
                        </p>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="icon-box">
                        <h4 class="fw-bold">Our Vision</h4>
                        <p class="text-muted mt-3">
                            To become a trusted industry leader known for excellence and innovation.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Team Section -->
    <section class="section-padding">
        <div class="container text-center">
            <h2 class="fw-bold mb-5">Meet Our Team</h2>
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="team-card">
                        <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Team Member">
                        <h5 class="mt-3 fw-bold">John Smith</h5>
                        <p class="text-muted">Founder & CEO</p>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="team-card">
                        <img src="https://randomuser.me/api/portraits/women/44.jpg" alt="Team Member">
                        <h5 class="mt-3 fw-bold">Emily Johnson</h5>
                        <p class="text-muted">Creative Director</p>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="team-card">
                        <img src="https://randomuser.me/api/portraits/men/75.jpg" alt="Team Member">
                        <h5 class="mt-3 fw-bold">Michael Lee</h5>
                        <p class="text-muted">Lead Developer</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
        <div class="container">
            <h2 class="fw-bold">Let’s Build Something Great Together</h2>
            <p class="mt-3">Ready to take your business to the next level?</p>
            <a href="#" class="btn btn-custom btn-lg mt-3">Contact Us</a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-4">
        <p class="mb-0">© 2026 YourBrand. All Rights Reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
