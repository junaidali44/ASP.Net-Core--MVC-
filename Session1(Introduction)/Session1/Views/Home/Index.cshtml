@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Professional Animated Homepage</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            scroll-behavior: smooth;
        }

        /* Navbar */
        .navbar {
            background: rgba(0,0,0,0.8);
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: 2px;
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            background: linear-gradient(135deg, #0d6efd, #6610f2);
            color: white;
            display: flex;
            align-items: center;
            text-align: center;
        }

            .hero h1 {
                font-size: 3rem;
                font-weight: 700;
                animation: fadeInDown 1s ease-in-out;
            }

            .hero p {
                font-size: 1.2rem;
                margin-top: 20px;
                animation: fadeInUp 1.2s ease-in-out;
            }

        .btn-custom {
            background: white;
            color: #0d6efd;
            font-weight: 600;
            border-radius: 30px;
            padding: 10px 25px;
            transition: 0.3s;
        }

            .btn-custom:hover {
                background: #000;
                color: #fff;
            }

        /* Section Padding */
        section {
            padding: 80px 0;
        }

        /* Cards */
        .card {
            border: none;
            transition: transform 0.4s ease, box-shadow 0.4s ease;
        }

            .card:hover {
                transform: translateY(-10px);
                box-shadow: 0 15px 30px rgba(0,0,0,0.2);
            }

        /* About Section */
        .about-img {
            border-radius: 15px;
        }

        /* CTA */
        .cta {
            background: linear-gradient(135deg, #6610f2, #0d6efd);
            color: white;
            text-align: center;
        }

        /* Footer */
        footer {
            background: #111;
            color: #aaa;
            padding: 20px 0;
            text-align: center;
        }
        
        

     
    </style>
</head>
<body>

    <!-- Navbar -->
 

    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="container">
            <h1>We Build Professional Websites</h1>
            <p>Creative, Modern & Fully Responsive Design Solutions</p>
            <a href="#services" class="btn btn-custom mt-4">Explore Services</a>
        </div>
    </section>

    <!-- About Section -->
    <section id="about">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6" data-aos="fade-right">
                    <img src="https://images.unsplash.com/photo-1492724441997-5dc865305da7" class="img-fluid about-img">
                </div>
                <div class="col-md-6" data-aos="fade-left">
                    <h2>About Us</h2>
                    <p>We are a professional digital agency delivering high-quality websites and applications using modern technologies.</p>
                    <p>Our goal is to create visually stunning and high-performance digital experiences.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="bg-light">
        <div class="container text-center">
            <h2 class="mb-5">Our Services</h2>
            <div class="row">
                <div class="col-md-4" data-aos="zoom-in">
                    <div class="card p-4">
                        <h4>Web Design</h4>
                        <p>Modern and responsive website designs tailored for your business.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="zoom-in" data-aos-delay="200">
                    <div class="card p-4">
                        <h4>Development</h4>
                        <p>High-performance and scalable web applications.</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="zoom-in" data-aos-delay="400">
                    <div class="card p-4">
                        <h4>SEO Optimization</h4>
                        <p>Improve your search engine ranking and online visibility.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
        <div class="container">
            <h2 data-aos="fade-up">Ready to Start Your Project?</h2>
            <a href="#contact" class="btn btn-light mt-3">Get In Touch</a>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6" data-aos="fade-up">
                    <h2 class="text-center mb-4">Contact Us</h2>
                    <form>
                        <div class="mb-3">
                            <input type="text" class="form-control" placeholder="Your Name" required>
                        </div>
                        <div class="mb-3">
                            <input type="email" class="form-control" placeholder="Your Email" required>
                        </div>
                        <div class="mb-3">
                            <textarea class="form-control" rows="4" placeholder="Your Message" required></textarea>
                        </div>
                        <div class="d-grid">
                            <button class="btn btn-primary">Send Message</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 MyBrand. All Rights Reserved.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- AOS JS -->
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true
        });
    </script>

</body>
</html>
