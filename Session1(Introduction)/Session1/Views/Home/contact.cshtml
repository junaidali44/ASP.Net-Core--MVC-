<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Contact Us</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 5 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f8f9fa;
        }

        .contact-header {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            color: white;
            padding: 80px 0;
            text-align: center;
        }

            .contact-header h1 {
                font-weight: 700;
            }

        .contact-card {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
        }

            .contact-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            }

        .form-control:focus {
            box-shadow: none;
            border-color: #0d6efd;
        }

        .btn-custom {
            background-color: #0d6efd;
            border: none;
        }

            .btn-custom:hover {
                background-color: #0b5ed7;
            }

        .map-container iframe {
            border-radius: 15px;
        }

        footer {
            background-color: #212529;
            color: white;
            padding: 20px 0;
        }
    </style>
</head>
<body>

    <!-- Hero Section -->
    <section class="contact-header">
        <div class="container">
            <h1>Contact Us</h1>
            <p class="lead">We’d love to hear from you. Get in touch with us!</p>
        </div>
    </section>

    <!-- Contact Info Cards -->
    <section class="py-5">
        <div class="container">
            <div class="row text-center g-4">

                <div class="col-md-4">
                    <div class="card contact-card p-4 shadow-sm">
                        <h5>📍 Address</h5>
                        <p>123 Business Street<br>New York, NY 10001</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card contact-card p-4 shadow-sm">
                        <h5>📞 Phone</h5>
                        <p>+1 (123) 456-7890</p>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card contact-card p-4 shadow-sm">
                        <h5>✉️ Email</h5>
                        <p>support@example.com</p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Contact Form & Map -->
    <section class="pb-5">
        <div class="container">
            <div class="row g-4">

                <!-- Contact Form -->
                <div class="col-lg-6">
                    <div class="card p-4 shadow-sm">
                        <h4 class="mb-4">Send a Message</h4>
                        <form>
                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input type="text" class="form-control" placeholder="Enter your name" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <input type="email" class="form-control" placeholder="Enter your email" required>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Subject</label>
                                <input type="text" class="form-control" placeholder="Subject">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Message</label>
                                <textarea class="form-control" rows="5" placeholder="Write your message..." required></textarea>
                            </div>

                            <button type="submit" class="btn btn-custom w-100 text-white">Send Message</button>
                        </form>
                    </div>
                </div>

                <!-- Google Map -->
                <div class="col-lg-6">
                    <div class="map-container shadow-sm">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3023.792!2d-73.9903!3d40.7505"
                                width="100%"
                                height="100%"
                                style="min-height: 400px;"
                                allowfullscreen=""
                                loading="lazy">
                        </iframe>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="text-center">
        <div class="container">
            <p class="mb-0">© 2026 Your Company. All rights reserved.</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
