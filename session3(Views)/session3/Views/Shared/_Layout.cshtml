<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - session3</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/session3.styles.css" asp-append-version="true" />
</head>
<body data-bs-spy="scroll" data-bs-target=".list-group" data-bs-offset="120" class="m-0 p-0">
    <!-- From Uiverse.io by dexter-st -->
    <div class="wrapper-grid">
        <div class="cube">
            <div class="face face-front">L</div>
            <div class="face face-back"></div>
            <div class="face face-right"></div>
            <div class="face face-left"></div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
        </div>

        <div class="cube">
            <div class="face face-front">O</div>
            <div class="face face-back"></div>
            <div class="face face-right"></div>
            <div class="face face-left"></div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
        </div>

        <div class="cube">
            <div class="face face-front">A</div>
            <div class="face face-back"></div>
            <div class="face face-right"></div>
            <div class="face face-left"></div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
        </div>

        <div class="cube">
            <div class="face face-front">D</div>
            <div class="face face-back"></div>
            <div class="face face-right"></div>
            <div class="face face-left"></div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
        </div>

        <div class="cube">
            <div class="face face-front">I</div>
            <div class="face face-back"></div>
            <div class="face face-right"></div>
            <div class="face face-left"></div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
        </div>

        <div class="cube">
            <div class="face face-front">N</div>
            <div class="face face-back"></div>
            <div class="face face-right"></div>
            <div class="face face-left"></div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
        </div>

        <div class="cube">
            <div class="face face-front">G</div>
            <div class="face face-back"></div>
            <div class="face face-right"></div>
            <div class="face face-left"></div>
            <div class="face face-top"></div>
            <div class="face face-bottom"></div>
        </div>
    </div>

    <header>
        <nav class="navbar navbar-expand-sm navbar-custom fixed-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold ms-5" asp-area="" asp-controller="Home" asp-action="Index">
                    True
                </a>
                     <span class="circle">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-alexa" viewBox="0 0 16 16">
                            <path d="M7.996 0A8 8 0 0 0 0 8a8 8 0 0 0 6.93 7.93v-1.613a1.06 1.06 0 0 0-.717-1.008A5.6 5.6 0 0 1 2.4 7.865 5.58 5.58 0 0 1 8.054 2.4a5.6 5.6 0 0 1 5.535 5.81l-.002.046-.012.192-.005.061a5 5 0 0 1-.033.284l-.01.068c-.685 4.516-6.564 7.054-6.596 7.068A7.998 7.998 0 0 0 15.992 8 8 8 0 0 0 7.996.001Z" />
                        </svg>
                    </span>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link active" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="About" asp-action="About">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="userinfo">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Users" asp-action="users">Users</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="Maincontainer">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-light pt-5 pb-4">
        <div class="container">
            <div class="row g-4">

                <!-- Brand / About -->
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-3">YourCompany</h5>
                    <p class="text-light">
                        We build modern digital solutions that help businesses grow,
                        scale, and succeed in a competitive market.
                    </p>

                    <!-- Social Icons -->
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-light fs-5 footer-icon">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="text-light fs-5 footer-icon">
                            <i class="bi bi-twitter"></i>
                        </a>
                        <a href="#" class="text-light fs-5 footer-icon">
                            <i class="bi bi-linkedin"></i>
                        </a>
                        <a href="#" class="text-light fs-5 footer-icon">
                            <i class="bi bi-instagram"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold mb-3">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="footer-link">Home</a></li>
                        <li><a href="#" class="footer-link">About</a></li>
                        <li><a href="#" class="footer-link">Services</a></li>
                        <li><a href="#" class="footer-link">Projects</a></li>
                        <li><a href="#" class="footer-link">Contact</a></li>
                    </ul>
                </div>

                <!-- Services -->
                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-3">Services</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="footer-link">Web Development</a></li>
                        <li><a href="#" class="footer-link">UI / UX Design</a></li>
                        <li><a href="#" class="footer-link">Digital Marketing</a></li>
                        <li><a href="#" class="footer-link">SEO Optimization</a></li>
                    </ul>
                </div>

                <!-- Newsletter -->
                <div class="col-lg-3 col-md-6">
                    <h6 class="fw-bold mb-3">Newsletter</h6>
                    <p class="text-light small">
                        Subscribe to get updates and insights.
                    </p>

                    <form class="d-flex mb-3">
                        <input type="email"
                               class="form-control form-control-sm me-2"
                               placeholder="Your email"
                               aria-label="Email address">
                        <button class="btn btn-primary btn-sm">
                            Subscribe
                        </button>
                    </form>

                    <p class="small text-light mb-0">
                        <i class="bi bi-geo-alt me-2"></i>123 Business Street, NY
                    </p>
                    <p class="small text-light mb-0">
                        <i class="bi bi-envelope me-2"></i>info@example.com
                    </p>
                    <p class="small text-light">
                        <i class="bi bi-telephone me-2"></i>+1 (123) 456-7890
                    </p>
                </div>

            </div>

            <hr class="border-secondary my-4">

            <!-- Bottom Row -->
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <p class="mb-2 mb-md-0 small text-light">
                    © 2026 YourCompany. All rights reserved.
                </p>

                <div class="d-flex gap-3">
                    <a href="#" class="footer-link small">Privacy Policy</a>
                    <a href="#" class="footer-link small">Terms of Service</a>
                </div>
            </div>
        </div>

        <!-- Back to Top Button -->
        <button onclick="window.scrollTo({top:0, behavior:'smooth'})"
                class="btn btn-primary rounded-circle shadow back-to-top"
                aria-label="Back to top">
            <i class="bi bi-arrow-up"></i>
        </button>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
