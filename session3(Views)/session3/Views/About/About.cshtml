
@{
    ViewData["Title"] = "About";
}

<!-- About Banner -->
<section class="bg-dark text-white text-center py-5"
         style="background: url('https://via.placeholder.com/1920x500') center/cover no-repeat;">
    <div class="container py-5">
        <h1 class="fw-bold display-4">About Us</h1>
        <p class="lead">Learn more about our journey, team, and projects.</p>
    </div>
</section>
<!-- About Content -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-md-6 mb-4 mb-md-0">
                <img src="https://via.placeholder.com/600x400" class="img-fluid rounded shadow" alt="About Image">
            </div>

            <div class="col-md-6">
                <h2 class="fw-bold mb-3">Who We Are</h2>
                <p class="text-muted">
                    We are a passionate team dedicated to delivering high-quality digital solutions.
                    Our expertise spans web development, UI/UX design, and digital marketing.
                </p>
                <p class="text-muted">
                    Our mission is to empower businesses with scalable, modern, and innovative solutions.
                </p>
                <a href="#" class="btn btn-primary mt-3">Contact Us</a>
            </div>

        </div>
    </div>
</section>
<!-- Team Section -->
<section class="bg-light py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Meet Our Team</h2>
            <p class="text-muted">The people behind our success</p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card border-0 shadow-sm text-center h-100">
                    <img src="https://via.placeholder.com/400x400" class="card-img-top" alt="">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">John Doe</h5>
                        <p class="text-muted">CEO & Founder</p>
                        <p class="small">Visionary leader with 10+ years of industry experience.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm text-center h-100">
                    <img src="https://via.placeholder.com/400x400" class="card-img-top" alt="">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Jane Smith</h5>
                        <p class="text-muted">Lead Designer</p>
                        <p class="small">Creative expert focused on user-centered design.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm text-center h-100">
                    <img src="https://via.placeholder.com/400x400" class="card-img-top" alt="">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Michael Lee</h5>
                        <p class="text-muted">Senior Developer</p>
                        <p class="small">Specialist in scalable and high-performance applications.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- Projects Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Our Projects</h2>
            <p class="text-muted">A showcase of our recent work</p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://via.placeholder.com/400x300" class="card-img-top" alt="">
                    <div class="card-body">
                        <h5 class="fw-bold">E-Commerce Website</h5>
                        <p class="text-muted small">
                            A modern online store with seamless checkout and payment integration.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://via.placeholder.com/400x300" class="card-img-top" alt="">
                    <div class="card-body">
                        <h5 class="fw-bold">Corporate Branding</h5>
                        <p class="text-muted small">
                            Complete branding solution including logo and marketing materials.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <img src="https://via.placeholder.com/400x300" class="card-img-top" alt="">
                    <div class="card-body">
                        <h5 class="fw-bold">Mobile App UI</h5>
                        <p class="text-muted small">
                            Clean and intuitive UI/UX design for a fintech mobile application.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- CTA Section -->
<section class="bg-primary text-white py-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">Ready to Start Your Project?</h2>
        <p class="mb-4">Let’s work together to create something amazing.</p>
        <a href="#" class="btn btn-light btn-lg px-4">Get Started</a>
    </div>
</section>
