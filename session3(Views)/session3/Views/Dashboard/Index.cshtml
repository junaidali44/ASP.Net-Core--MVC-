
@{
    ViewData["Title"] = "Index";
}
      <!-- Main Content -->
            <div class="container-fluid">
                <h2 class="mb-4">Dashboard Overview</h2>

                <!-- Example Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-md-3">
                        <div class="card shadow-sm p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Users</h6>
                                    <h4>1,245</h4>
                                </div>
                                <i class="bi bi-people fs-2 text-primary"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Projects</h6>
                                    <h4>87</h4>
                                </div>
                                <i class="bi bi-folder2-open fs-2 text-success"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Revenue</h6>
                                    <h4>$32,400</h4>
                                </div>
                                <i class="bi bi-currency-dollar fs-2 text-warning"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card shadow-sm p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-muted">Reports</h6>
                                    <h4>24</h4>
                                </div>
                                <i class="bi bi-bar-chart-line fs-2 text-danger"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Example Table -->
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Recent Users</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>City</th>
                                        <th>Registered</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>1</td>
                                        <td>John Doe</td>
                                        <td>john@example.com</td>
                                        <td>New York</td>
                                        <td><span class="badge bg-success">Yes</span></td>
                                    </tr>
                                    <tr>
                                        <td>2</td>
                                        <td>Jane Smith</td>
                                        <td>jane@example.com</td>
                                        <td>London</td>
                                        <td><span class="badge bg-danger">No</span></td>
                                    </tr>
                                    <tr>
                                        <td>3</td>
                                        <td>Michael Lee</td>
                                        <td>michael@example.com</td>
                                        <td>Berlin</td>
                                        <td><span class="badge bg-success">Yes</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
  
   