@{
    ViewData["Title"] = "Privacy Policy";
}
<h1>@ViewData["Title"]</h1>

<!-- Privacy Policy Banner -->
<section class="bg-dark text-white text-center py-5">
    <div class="container">
        <h1 class="fw-bold display-5">Privacy Policy</h1>
        <p class="lead mb-0">
            Your privacy is important to us. This policy explains how we collect and use your information.
        </p>
        <p class="small text-muted mt-2">
            Last Updated: January 1, 2026
        </p>
    </div>
</section>
<!-- Privacy Policy Content -->
<section class="py-5">
    <div class="container">
        <div class="row">

            <!-- Optional Sidebar Navigation -->
            <div class="col-lg-3 mb-4">
                <div class="list-group sticky-top" style="top:100px;">
                    <a href="#info-collect" class="list-group-item list-group-item-action">Information We Collect</a>
                    <a href="#how-use" class="list-group-item list-group-item-action">How We Use Information</a>
                    <a href="#cookies" class="list-group-item list-group-item-action">Cookies</a>
                    <a href="#data-sharing" class="list-group-item list-group-item-action">Data Sharing</a>
                    <a href="#security" class="list-group-item list-group-item-action">Data Security</a>
                    <a href="#rights" class="list-group-item list-group-item-action">Your Rights</a>
                    <a href="#contact" class="list-group-item list-group-item-action">Contact Us</a>
                </div>
            </div>

            <!-- Policy Content -->
            <div class="col-lg-9">

                <div id="info-collect" class="mb-5">
                    <h4 class="fw-bold">1. Information We Collect</h4>
                    <p class="text-muted">
                        We may collect personal information such as your name, email address,
                        phone number, and company details when you contact us or use our services.
                    </p>
                    <p class="text-muted">
                        We may also collect non-personal information including browser type,
                        device information, and website usage data.
                    </p>
                </div>

                <div id="how-use" class="mb-5">
                    <h4 class="fw-bold">2. How We Use Your Information</h4>
                    <ul class="text-muted">
                        <li>To provide and improve our services</li>
                        <li>To communicate with you</li>
                        <li>To process transactions</li>
                        <li>To send updates or promotional materials (if subscribed)</li>
                    </ul>
                </div>

                <div id="cookies" class="mb-5">
                    <h4 class="fw-bold">3. Cookies</h4>
                    <p class="text-muted">
                        Our website may use cookies to enhance user experience,
                        analyze traffic, and personalize content.
                    </p>
                </div>

                <div id="data-sharing" class="mb-5">
                    <h4 class="fw-bold">4. Data Sharing & Disclosure</h4>
                    <p class="text-muted">
                        We do not sell or trade your personal information.
                        We may share information with trusted partners who assist
                        in operating our website or servicing you.
                    </p>
                </div>

                <div id="security" class="mb-5">
                    <h4 class="fw-bold">5. Data Security</h4>
                    <p class="text-muted">
                        We implement appropriate technical and organizational measures
                        to protect your data against unauthorized access, alteration, or disclosure.
                    </p>
                </div>

                <div id="rights" class="mb-5">
                    <h4 class="fw-bold">6. Your Rights</h4>
                    <p class="text-muted">
                        You have the right to request access to, correction of,
                        or deletion of your personal information.
                    </p>
                </div>

                <div id="contact" class="mb-5">
                    <h4 class="fw-bold">7. Contact Us</h4>
                    <p class="text-muted">
                        If you have any questions about this Privacy Policy,
                        please contact us at:
                    </p>
                    <p class="text-muted mb-0">
                        <strong>Email:</strong> info@example.com
                    </p>
                    <p class="text-muted">
                        <strong>Phone:</strong> +1 (123) 456-7890
                    </p>
                </div>

            </div>

        </div>
    </div>
</section>
