@model Contact
@{
    ViewData["Title"] = "Contact";
}

<!-- Contact Banner -->
<section class="bg-primary text-white text-center py-5"
         style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
         url('https://via.placeholder.com/1920x500') center/cover no-repeat;">
    <div class="container py-5">
        <h1 class="fw-bold display-4">Contact Us</h1>
        <p class="lead">We’d love to hear from you. Get in touch with us!</p>
    </div>
</section>
<!-- Contact Info -->
<section class="py-5">
    <div class="container">
        <div class="row text-center g-4">

            <div class="col-md-4">
                <div class="p-4 shadow-sm border rounded h-100">
                    <i class="bi bi-geo-alt fs-1 text-primary"></i>
                    <h5 class="fw-bold mt-3">Our Location</h5>
                    <p class="text-muted mb-0">123 Business Street<br>New York, USA</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 shadow-sm border rounded h-100">
                    <i class="bi bi-envelope fs-1 text-primary"></i>
                    <h5 class="fw-bold mt-3">Email Us</h5>
                    <p class="text-muted mb-0">info@example.com<br>support@example.com</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-4 shadow-sm border rounded h-100">
                    <i class="bi bi-telephone fs-1 text-primary"></i>
                    <h5 class="fw-bold mt-3">Call Us</h5>
                    <p class="text-muted mb-0">+1 (123) 456-7890<br>+1 (987) 654-3210</p>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- Contact Form -->
<section class="bg-light py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card shadow-sm border-0">
                    <div class="card-body p-5">
                        <h3 class="fw-bold mb-4 text-center">Send Us a Message</h3>

                       

                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
<!-- Map Section -->
<section class="p-0">
    <iframe src="https://maps.google.com/maps?q=New%20York&t=&z=13&ie=UTF8&iwloc=&output=embed"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy">
    </iframe>
</section>
