@model Contact
<div class="container">
    <div class="row">
<form asp-controller="Contact" asp-action="userinfo" method="post">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Full Name</label>
            <input asp-for="name" type="text" class="form-control" placeholder="Your Name">
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Email Address</label>
            <input asp-for="email" type="email" class="form-control" placeholder="Your Email">
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Subject</label>
        <input asp-for="subject" type="text" class="form-control" placeholder="Subject">
    </div>

    <div class="mb-3">
        <label class="form-label">Message</label>
        <textarea asp-for="messeage" class="form-control" rows="5" placeholder="Your Message"></textarea>
    </div>

    <div class="text-center">
        <button type="submit" class="btn btn-primary px-5">Send Message</button>
    </div>
</form>
    </div>
    </div>