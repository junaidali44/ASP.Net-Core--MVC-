@{
    ViewData["Title"] = "Home Page";
}

<!-- Navbar -->
<!-- Hero Section -->
<section class="bg-light text-dark text-center py-5">
    <div class="container">
        <h1 class="display-4 fw-bold">Welcome to Our Website</h1>
        <p class="lead">We provide modern solutions for your business</p>
        <a href="#" class="btn btn-primary btn-lg mt-3">Get Started</a>
    </div>
</section>

<!-- Features Section -->
<section class="py-5">
    <div class="container">
        <div class="row text-center">

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">Fast Performance</h5>
                        <p class="card-text">Optimized solutions to deliver high speed and reliability.</p>
                        <a href="#" class="btn btn-outline-primary btn-sm">Learn More</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">Secure System</h5>
                        <p class="card-text">Advanced security features to protect your data.</p>
                        <a href="#" class="btn btn-outline-primary btn-sm">Learn More</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title">24/7 Support</h5>
                        <p class="card-text">Our team is available anytime to assist you.</p>
                        <a href="#" class="btn btn-outline-primary btn-sm">Learn More</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- About Section -->
<section class="bg-light py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <img src="https://via.placeholder.com/500x350" class="img-fluid rounded" alt="About Image">
            </div>
            <div class="col-md-6">
                <h2>About Us</h2>
                <p>We are a creative company focused on building modern web applications and digital experiences.</p>
                <a href="#" class="btn btn-primary">Read More</a>
            </div>
        </div>
    </div>
</section>

<!-- Call To Action -->
<section class="bg-primary text-white text-center py-5">
    <div class="container">
        <h2>Ready to Start Your Project?</h2>
        <p class="lead">Let’s build something amazing together.</p>
        <a href="#" class="btn btn-light btn-lg">Contact Us</a>
    </div>
</section>

<!-- Footer -->
<footer class="bg-dark text-white text-center py-4">
    <div class="container">
        <p class="mb-0">&copy; 2026 BrandName. All Rights Reserved.</p>
    </div>
</footer>
    
