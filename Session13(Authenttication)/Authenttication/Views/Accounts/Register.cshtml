@model Authenttication.ViewModel.RegisterViewModel;
<div class="container">
<h1 class="title">Register</h1>   
    <form class="form" asp-controller="Accounts" asp-action="Register">
        <div class="mb-3">
            <label class="form-label">Username</label>
            <input asp-for="Username" type="text" class="form-control" required></div>
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" required></div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" required></div>
        <button type="submit" class="btn btn-primary w-100">Sign Up</button>
    </form>
</div>